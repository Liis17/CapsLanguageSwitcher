<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <sys:String x:Key="WindowTitle">CapsLanguageSwitcher</sys:String>
    <sys:String x:Key="AppTitle">CapsLock Language Switcher</sys:String>
    <sys:String x:Key="Description">Нажмите CapsLock для переключения раскладки клавиатуры.</sys:String>
    <sys:String x:Key="Hint">Приложение можно свернуть — оно продолжит работу в трее.</sys:String>

    <sys:String x:Key="AdminWarningTitle">Внимание</sys:String>
    <sys:String x:Key="AdminWarningBody">Окна, запущенные от имени администратора, могут блокировать перехват CapsLock. Запустите приложение с правами администратора, чтобы переключение работало в таких окнах.</sys:String>

    <sys:String x:Key="SwitchMethodLabel">Метод переключения раскладки</sys:String>
    <sys:String x:Key="MethodPostMessage">PostMessage (классический)</sys:String>
    <sys:String x:Key="MethodSendInput">Симуляция Win+Space (универсальный)</sys:String>

    <sys:String x:Key="LanguageLabel">Язык интерфейса</sys:String>
    <sys:String x:Key="AutoStart">Запускать с Windows</sys:String>

    <sys:String x:Key="TrayOpen">Открыть</sys:String>
    <sys:String x:Key="TrayExit">Выход</sys:String>
    <sys:String x:Key="TrayTooltip">CapsLock → Переключатель языка</sys:String>

    <sys:String x:Key="HookErrorTitle">Ошибка перехватчика клавиатуры</sys:String>
    <sys:String x:Key="HookErrorBody">Не удалось установить глобальный перехватчик клавиатуры. Приложение продолжит работу, но переключение раскладки по CapsLock будет недоступно до перезапуска.</sys:String>
</ResourceDictionary>

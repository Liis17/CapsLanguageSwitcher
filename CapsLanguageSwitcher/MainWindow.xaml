<Window
    x:Class="CapsLanguageSwitcher.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:CapsLanguageSwitcher"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="{DynamicResource WindowTitle}"
    Width="500"
    Height="540"
    Background="#1e1e1e"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Window.InputBindings>
        <KeyBinding
            Key="Q"
            Command="{Binding ExitAppCommand, RelativeSource={RelativeSource AncestorType=Window}}"
            Modifiers="Control" />
    </Window.InputBindings>

    <Window.Resources>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#DDDDDD" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,12,0,4" />
        </Style>
    </Window.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,60">
                <TextBlock
                    FontSize="22"
                    FontWeight="Bold"
                    Foreground="White"
                    Text="{DynamicResource AppTitle}"
                    TextAlignment="Center"
                    TextWrapping="Wrap" />

                <TextBlock
                    Margin="0,10,0,0"
                    FontSize="13"
                    Foreground="#CCCCCC"
                    Text="{DynamicResource Description}"
                    TextAlignment="Center"
                    TextWrapping="Wrap" />

                <TextBlock
                    Margin="0,4,0,0"
                    FontSize="12"
                    Foreground="#999999"
                    Text="{DynamicResource Hint}"
                    TextAlignment="Center"
                    TextWrapping="Wrap" />

                <Border
                    Margin="0,16,0,0"
                    Padding="10"
                    Background="#3a2a14"
                    BorderBrush="#a06a20"
                    BorderThickness="1"
                    CornerRadius="4">
                    <StackPanel>
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="#FFCC88"
                            Text="{DynamicResource AdminWarningTitle}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="12"
                            Foreground="#FFE2B8"
                            Text="{DynamicResource AdminWarningBody}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <TextBlock Style="{StaticResource LabelText}" Text="{DynamicResource SwitchMethodLabel}" />
                <ComboBox
                    x:Name="MethodComboBox"
                    SelectionChanged="MethodComboBox_SelectionChanged">
                    <ComboBoxItem Content="{DynamicResource MethodPostMessage}" Tag="PostMessage" />
                    <ComboBoxItem Content="{DynamicResource MethodSendInput}" Tag="SendInput" />
                </ComboBox>

                <TextBlock Style="{StaticResource LabelText}" Text="{DynamicResource LanguageLabel}" />
                <ComboBox
                    x:Name="LanguageComboBox"
                    SelectionChanged="LanguageComboBox_SelectionChanged">
                    <ComboBoxItem Content="Русский" Tag="ru" />
                    <ComboBoxItem Content="English" Tag="en" />
                </ComboBox>

                <CheckBox
                    x:Name="AutoStartCheckBox"
                    Margin="0,16,0,0"
                    Checked="AutoStartCheckBox_Checked"
                    Content="{DynamicResource AutoStart}"
                    Foreground="White"
                    Unchecked="AutoStartCheckBox_Unchecked" />
            </StackPanel>
        </ScrollViewer>

        <TextBlock
            x:Name="VersionTextBlock"
            Margin="0,0,8,4"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Foreground="White"
            Opacity="0.3"
            Text="v" />
    </Grid>
</Window>
